{
  "name": "diceui",
  "packageManager": "pnpm@10.33.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "docs",
    "packages/*"
  ],
  "scripts": {
    "clean": "rimraf --glob **/node_modules **/dist **/.source **/.turbo **/.next **/pnpm-lock.yaml **/.tsbuildinfo",
    "clean:cache": "rimraf --glob **/.turbo **/.next/cache **/node_modules/.cache **/node_modules/.vite",
    "build": "turbo run build",
    "build:registry": "pnpm --filter=docs build:registry --loglevel silent",
    "validate:registry": "pnpm --filter=docs validate:registry --loglevel silent",
    "cleanup:registry": "pnpm --filter=docs cleanup:registry --loglevel silent",
    "test:registry": "pnpm --filter=docs test:registry --loglevel silent",
    "build:packages": "pnpm --filter \"@diceui/*\" build",
    "dev": "turbo run dev",
    "docs:dev": "turbo run dev --filter=docs",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "typecheck": "turbo run typecheck",
    "check": "turbo run lint typecheck",
    "test": "turbo run test",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@changesets/cli": "^2.30.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-react": "^6.0.1",
    "expect-type": "^1.3.0",
    "jsdom": "^29.0.1",
    "rimraf": "^6.1.3",
    "turbo": "^2.8.21",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
